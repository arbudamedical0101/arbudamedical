{
  "name": "pharmacy-server",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "description": "Express + TypeScript + Mongoose API for retail pharmacy management",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "tsx src/seed/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.16.0",
    "serverless-http": "^4.0.0",
    "@vercel/node": "^5.0.0",
    "zod": "^3.24.1",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/pdfkit": "^0.13.9",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.19.2"
  }
}
