# --- Server configuration ---
PORT=5000
NODE_ENV=development

# Client origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# Set to true to run a zero-install in-memory MongoDB replica set for local dev
# (downloads a MongoDB binary on first run). When true, MONGODB_URI is ignored
# and demo data is auto-seeded on startup.
USE_MEMORY_DB=false

# MongoDB connection string.
# IMPORTANT: transactions require a replica set. Options:
#   - MongoDB Atlas (replica set by default), or
#   - a local single-node replica set, e.g. mongodb://localhost:27017/pharmacy?replicaSet=rs0
MONGODB_URI=mongodb://localhost:27017/pharmacy?replicaSet=rs0

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Local folder for uploaded prescription images (served at /uploads)
UPLOAD_DIR=uploads

# Default admin user created by the seed script
SEED_ADMIN_EMAIL=admin@pharmacy.local
SEED_ADMIN_PASSWORD=Admin@123
